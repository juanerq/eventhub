---
interface Props {
  id?: string;
}

const { id = "location-filter" } = Astro.props;
---

<div class="map-location-filter">
  <div class="location-controls">
    <!-- Search by address -->
    <div class="search-location-group">
      <label class="search-label">Buscar ubicación</label>
      <div class="search-input-wrapper">
        <input
          type="text"
          id="location-search-input"
          class="location-search-input"
          placeholder="Ciudad, dirección o lugar..."
        />
        <button
          type="button"
          class="btn-search-location"
          id="search-location-btn"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"
            ></circle>
            <path
              d="m21 21-4.35-4.35"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"></path>
          </svg>
          Buscar
        </button>
      </div>
    </div>

    <!-- Divider -->
    <div class="location-divider">
      <span>o</span>
    </div>

    <!-- Use my location button -->
    <button type="button" class="btn-get-location" id="get-user-location">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <path
          d="M12 2L12 6M12 18L12 22M22 12L18 12M6 12L2 12M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <span id="location-status">Usar mi ubicación</span>
    </button>

    <div
      class="distance-selector"
      id="distance-selector"
      style="display: none;"
    >
      <label for="distance-range"
        >Distancia: <strong id="distance-value">10</strong> km</label
      >
      <input
        type="range"
        id="distance-range"
        min="1"
        max="100"
        value="10"
        step="1"
        class="distance-slider"
      />
      <div class="distance-labels">
        <span>1 km</span>
        <span>100 km</span>
      </div>
    </div>
  </div>

  <div class="map-container" id="location-map" style="display: none;"></div>

  <div class="location-info" id="location-info" style="display: none;">
    <p class="info-text">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"
        ></circle>
        <path
          d="M12 16v-4m0-4h.01"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"></path>
      </svg>
      Mostrando eventos cerca de tu ubicación
    </p>
  </div>
</div>

<style>
  .map-location-filter {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .location-controls {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .search-location-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .search-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  .search-input-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .location-search-input {
    width: 100%;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    color: white;
    font-size: 0.875rem;
    outline: none;
    transition: all 0.2s;
  }

  .location-search-input:focus {
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--primary, #9333ea);
  }

  .location-search-input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .btn-search-location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-search-location:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: var(--primary, #9333ea);
  }

  .btn-search-location:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .location-divider {
    display: flex;
    align-items: center;
    text-align: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    margin: 0.5rem 0;
  }

  .location-divider::before,
  .location-divider::after {
    content: "";
    flex: 1;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .location-divider span {
    padding: 0 0.75rem;
  }

  .btn-get-location {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background: linear-gradient(
      135deg,
      var(--primary, #9333ea),
      var(--primary-dark, #7e22ce)
    );
    color: white;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 2px 8px rgba(147, 51, 234, 0.3);
  }

  .btn-get-location:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(147, 51, 234, 0.4);
  }

  .btn-get-location:active {
    transform: translateY(0);
  }

  .btn-get-location:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .btn-get-location svg {
    flex-shrink: 0;
  }

  .distance-selector {
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
  }

  .distance-selector label {
    display: block;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0.75rem;
  }

  .distance-selector strong {
    color: var(--primary, #9333ea);
    font-size: 1rem;
  }

  .distance-slider {
    width: 100%;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    cursor: pointer;
  }

  .distance-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 18px;
    height: 18px;
    background: var(--primary, #9333ea);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(147, 51, 234, 0.4);
    transition: all 0.2s;
  }

  .distance-slider::-webkit-slider-thumb:hover {
    transform: scale(1.1);
    box-shadow: 0 3px 8px rgba(147, 51, 234, 0.6);
  }

  .distance-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    background: var(--primary, #9333ea);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(147, 51, 234, 0.4);
    transition: all 0.2s;
  }

  .distance-slider::-moz-range-thumb:hover {
    transform: scale(1.1);
    box-shadow: 0 3px 8px rgba(147, 51, 234, 0.6);
  }

  .distance-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .map-container {
    width: 100%;
    height: 200px;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.2);
  }

  .location-info {
    padding: 0.75rem;
    background: rgba(147, 51, 234, 0.1);
    border: 1px solid rgba(147, 51, 234, 0.3);
    border-radius: 0.5rem;
  }

  .info-text {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.813rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .info-text svg {
    flex-shrink: 0;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .map-container {
      height: 150px;
    }
  }
</style>
