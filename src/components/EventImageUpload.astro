---
/**
 * EventImageUpload - Componente reutilizable para subir imágenes de eventos
 * Maneja tanto imágenes nuevas como existentes (en modo edición)
 */
import ImageGalleryPreview from "./ImageGalleryPreview.astro";

interface Props {
  existingImages?: Array<{
    id: string;
    image_url: string;
    is_primary: boolean;
    display_order: number;
  }>;
  maxImages?: number;
}

const { existingImages = [], maxImages = 10 } = Astro.props;
---

<div class="event-image-upload">
  <h2 class="section-title">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
      <rect
        x="3"
        y="3"
        width="18"
        height="18"
        rx="2"
        stroke="currentColor"
        stroke-width="2"></rect>
      <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"></circle>
      <path
        d="M21 15l-5-5L5 21"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
    Imágenes del Evento
    <span class="image-count" id="image-count">({existingImages.length}/{maxImages})</span>
  </h2>

  <div class="form-row">
    <div class="form-group full">
      <!-- Contenedor único para TODAS las imágenes (existentes + nuevas) -->
      <div id="all-images-container" class="images-grid-container">
        <!-- Grid de imágenes existentes (solo en modo edición) -->
        {
          existingImages.length > 0 && (
            <div id="existing-images-grid" class="images-grid">
              {existingImages.map((img, idx) => (
                <div class="image-item" data-image-id={img.id}>
                  <img src={img.image_url} alt={`Imagen ${idx + 1}`} />
                  {img.is_primary && <span class="primary-badge">Principal</span>}
                  <button
                    type="button"
                    class="btn-remove-existing"
                    data-image-id={img.id}
                  >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M18 6L6 18M6 6l12 12"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </svg>
                  </button>
                </div>
              ))}
            </div>
          )
        }
        
        <!-- Preview de nuevas imágenes - se renderizará inline aquí -->
        <ImageGalleryPreview id="new-images-preview" maxImages={maxImages} />
      </div>

      <!-- Input para nuevas imágenes -->
      <div class="file-upload-wrapper" id="images-upload-wrapper">
        <input
          type="file"
          id="event_images"
          name="event_images"
          accept="image/*"
          multiple
          class="file-input-hidden"
        />
        <label for="event_images" class="file-upload-area" id="file-upload-label">
          <div class="file-upload-icon">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </div>
          <div class="file-upload-text">
            <span class="file-upload-title">Arrastra imágenes o haz clic</span>
            <span class="file-upload-subtitle">Selecciona varias a la vez</span>
          </div>
          <div class="file-upload-specs">JPG, PNG, WEBP · Máx. 5MB</div>
        </label>
      </div>

      <!-- Input oculto para trackear imágenes a eliminar (solo en modo edición) -->
      {existingImages.length > 0 && (
        <input type="hidden" id="images_to_remove" name="images_to_remove" value="" />
      )}

      <span class="error-message" id="event_images-error"></span>
    </div>
  </div>
</div>

<style>
  .event-image-upload {
    width: 100%;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title svg {
    color: var(--primary);
  }

  .image-count {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full {
    grid-column: 1 / -1;
    overflow: hidden;
    max-width: 100%;
  }

  /* Contenedor unificado para todas las imágenes */
  .images-grid-container {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
    min-height: 0;
  }

  .images-grid-container:empty {
    display: none;
  }

  /* Grid de imágenes existentes */
  .images-grid {
    display: contents; /* Las imágenes se integran directamente en el flex del padre */
  }

  .image-item {
    position: relative;
    width: 150px;
    min-width: 150px;
    max-width: 150px;
    height: 150px;
    min-height: 150px;
    max-height: 150px;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid var(--border);
    flex-shrink: 0;
    transition: all 0.2s ease;
  }

  .image-item:hover {
    transform: scale(1.02);
    border-color: var(--primary);
    box-shadow: 0 4px 12px rgba(147, 51, 234, 0.3);
  }

  .image-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-item .primary-badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    color: white;
    font-size: 0.7rem;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .image-item .btn-remove-existing {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 32px;
    height: 32px;
    background: rgba(0, 0, 0, 0.85);
    border: 2px solid white;
    border-radius: 50%;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.2s ease;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .image-item:hover .btn-remove-existing {
    opacity: 1;
  }

  .image-item .btn-remove-existing:hover {
    background: #e74c3c;
    transform: scale(1.1);
  }
  
  .image-item .btn-remove-existing svg {
    width: 16px;
    height: 16px;
  }

  /* File Upload Styles */
  .file-upload-wrapper {
    position: relative;
    max-width: 100%;
    overflow: hidden;
  }

  .file-input-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .file-upload-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1.5rem;
    background: rgba(255, 255, 255, 0.03);
    border: 2px dashed var(--border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  .file-upload-area::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--violet-600), var(--fuchsia-600));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .file-upload-area:hover::before {
    opacity: 0.05;
  }

  .file-upload-area:hover {
    border-color: var(--primary);
    background: rgba(147, 51, 234, 0.05);
    transform: translateY(-2px);
  }

  .file-upload-area:active {
    transform: translateY(0);
  }

  .file-upload-area.drag-over {
    border-color: var(--accent);
    background: rgba(217, 70, 239, 0.1);
    transform: scale(1.02);
  }

  .file-upload-icon {
    margin-bottom: 0.5rem;
    color: var(--primary);
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
  }

  .file-upload-icon svg {
    width: 32px;
    height: 32px;
  }

  .file-upload-area:hover .file-upload-icon {
    color: var(--accent);
    transform: translateY(-2px);
  }

  .file-upload-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
    position: relative;
    z-index: 1;
  }

  .file-upload-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text);
  }

  .file-upload-subtitle {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .file-upload-specs {
    font-size: 0.75rem;
    color: var(--text-muted);
    padding: 0.375rem 0.75rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    position: relative;
    z-index: 1;
  }

  .error-message {
    display: block;
    color: #ef4444;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    min-height: 1.25rem;
    animation: shake 0.3s ease;
  }

  .error-message:empty {
    display: none;
  }

  @keyframes shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-5px);
    }
    75% {
      transform: translateX(5px);
    }
  }

  @media (max-width: 768px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .image-item {
      width: 120px;
      min-width: 120px;
      max-width: 120px;
      height: 120px;
      min-height: 120px;
      max-height: 120px;
    }
  }
</style>
