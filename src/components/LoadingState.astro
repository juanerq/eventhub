---
interface Props {
  message?: string;
}

const { message = "Cargando..." } = Astro.props;
---

<div class="loading-state">
  <div class="spinner"></div>
  <p>{message}</p>
</div>

<style>
  .loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    gap: 1rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 4px solid rgba(147, 51, 234, 0.1);
    border-top-color: var(--primary, #9333ea);
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .loading-state p {
    color: var(--text-muted, #94a3b8);
    font-size: 1.1rem;
  }
</style>
