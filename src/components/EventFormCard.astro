---
/**
 * EventFormCard - Componente reutilizable para tarjetas de formulario
 */
interface Props {
  title: string;
  icon: string;
  delay?: number;
}

const { title, icon, delay = 0 } = Astro.props;
---

<div class="form-card" style={`animation-delay: ${delay * 0.1}s`}>
  <h2 class="section-title">
    <Fragment set:html={icon} />
    {title}
  </h2>
  <slot />
</div>

<style>
  .form-card {
    background: rgba(37, 37, 64, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease;
    animation-fill-mode: both;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title :global(svg) {
    color: var(--primary);
  }

  @media (max-width: 768px) {
    .form-card {
      padding: 1.5rem;
    }
  }
</style>
