---
import Layout from "../layouts/Layout.astro";
import { getUser } from "../lib/auth";

const user = await getUser(Astro.cookies);

if (!user) {
  return Astro.redirect("/login");
}

const userName =
  user.user_metadata?.full_name || user.email?.split("@")[0] || "Usuario";
const isOrganizer = user.user_metadata?.is_organizer || false;
---

<Layout title="Mi Perfil">
  <div class="profile">
    <nav class="navbar">
      <div class="nav-container">
        <a href="/dashboard" class="logo">EventHub</a>
        <a href="/dashboard" class="btn-back">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              d="M12 4l-6 6 6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>Volver</span>
        </a>
      </div>
    </nav>

    <main class="main-content">
      <div class="container">
        <div class="header">
          <div class="profile-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
              <path
                d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </div>
          <h1>{userName}</h1>
          <p class="email">{user.email}</p>
          {
            isOrganizer && (
              <div class="organizer-badge">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path
                    d="M10 2l2.5 5.5L18 8.5l-4.5 4 1 6-4.5-2.5L5 18.5l1-6L1.5 8.5l5.5-1L10 2z"
                    fill="currentColor"
                  />
                </svg>
                <span>Organizador</span>
              </div>
            )
          }
        </div>

        {
          isOrganizer && (
            <div class="plan-section">
              <div class="section-header">
                <h2>
                  Tu Plan de Suscripción{" "}
                  <span class="plan-type-badge" id="plan-type-badge">
                    Cargando...
                  </span>{" "}
                  <span class="plan-header-price" id="plan-header-price">
                    $0/mes
                  </span>
                </h2>
              </div>

              <div class="plan-card" id="plan-card">
                <div class="plan-stats">
                  <div class="stat-card">
                    <div class="stat-icon">📅</div>
                    <div class="stat-content">
                      <div class="stat-label">Eventos activos</div>
                      <div class="stat-value">
                        <span id="events-current">-</span>
                        <span class="stat-max" id="events-max">
                          / -
                        </span>
                      </div>
                      <div class="stat-bar">
                        <div class="stat-bar-fill" id="events-bar" />
                      </div>
                    </div>
                  </div>

                  <div class="stat-card">
                    <div class="stat-icon">👥</div>
                    <div class="stat-content">
                      <div class="stat-label">Capacidad por evento</div>
                      <div class="stat-value" id="capacity-max">
                        -
                      </div>
                    </div>
                  </div>

                  <div class="stat-card">
                    <div class="stat-icon">⭐</div>
                    <div class="stat-content">
                      <div class="stat-label">Eventos destacados</div>
                      <div class="stat-value" id="featured-status">
                        No disponible
                      </div>
                    </div>
                  </div>
                </div>

                <div class="plan-actions" id="plan-actions">
                  <button
                    class="btn-upgrade"
                    id="upgrade-btn"
                    style="display: none;"
                  >
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                      <path
                        d="M10 2l2.5 5.5L18 8.5l-4.5 4 1 6-4.5-2.5L5 18.5l1-6L1.5 8.5l5.5-1L10 2z"
                        fill="currentColor"
                      />
                    </svg>
                    Actualizar a PRO
                  </button>
                  <p
                    class="upgrade-benefits"
                    id="upgrade-benefits"
                    style="display: none;"
                  >
                    ✨ Eventos ilimitados · 👥 Capacidad ilimitada · ⭐ Eventos
                    destacados
                  </p>
                </div>
              </div>
            </div>
          )
        }

        <div class="info-section">
          <h3>Información de la cuenta</h3>
          <div class="info-grid">
            <div class="info-item">
              <label>Nombre completo</label>
              <p>{userName}</p>
            </div>
            <div class="info-item">
              <label>Email</label>
              <p>{user.email}</p>
            </div>
            <div class="info-item">
              <label>Tipo de cuenta</label>
              <p>{isOrganizer ? "Organizador" : "Usuario"}</p>
            </div>
            <div class="info-item">
              <label>Miembro desde</label>
              <p id="member-since">-</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  :root {
    /* Violet - Primary brand */
    --violet-50: #faf5ff;
    --violet-100: #f3e8ff;
    --violet-200: #e9d5ff;
    --violet-300: #d8b4fe;
    --violet-400: #c084fc;
    --violet-500: #a855f7;
    --violet-600: #9333ea;
    --violet-700: #7e22ce;
    --violet-800: #6b21a8;
    --violet-900: #581c87;
    --violet-950: #3b0764;

    /* Fuchsia/Magenta - Energetic accent */
    --fuchsia-50: #fdf4ff;
    --fuchsia-100: #fae8ff;
    --fuchsia-200: #f5d0fe;
    --fuchsia-300: #f0abfc;
    --fuchsia-400: #e879f9;
    --fuchsia-500: #d946ef;
    --fuchsia-600: #c026d3;
    --fuchsia-700: #a21caf;
    --fuchsia-800: #86198f;
    --fuchsia-900: #701a75;

    /* Orange/Coral - Warm energy */
    --orange-50: #fff7ed;
    --orange-100: #ffedd5;
    --orange-200: #fed7aa;
    --orange-300: #fdba74;
    --orange-400: #fb923c;
    --orange-500: #f97316;
    --orange-600: #ea580c;
    --orange-700: #c2410c;
    --orange-800: #9a3412;
    --orange-900: #7c2d12;

    /* Cyan - Cool highlight */
    --cyan-50: #ecfeff;
    --cyan-100: #cffafe;
    --cyan-200: #a5f3fc;
    --cyan-300: #67e8f9;
    --cyan-400: #22d3ee;
    --cyan-500: #06b6d4;
    --cyan-600: #0891b2;
    --cyan-700: #0e7490;
    --cyan-800: #155e75;
    --cyan-900: #164e63;

    /* Emerald/Green - Success & Growth */
    --emerald-50: #ecfdf5;
    --emerald-100: #d1fae5;
    --emerald-200: #a7f3d0;
    --emerald-300: #6ee7b7;
    --emerald-400: #34d399;
    --emerald-500: #10b981;
    --emerald-600: #059669;
    --emerald-700: #047857;
    --emerald-800: #065f46;
    --emerald-900: #064e3b;

    /* Deep Blue/Navy - Professional dark */
    --navy-50: #f0f9ff;
    --navy-100: #e0f2fe;
    --navy-200: #bae6fd;
    --navy-300: #7dd3fc;
    --navy-400: #38bdf8;
    --navy-500: #0ea5e9;
    --navy-600: #0284c7;
    --navy-700: #0369a1;
    --navy-800: #075985;
    --navy-900: #0c4a6e;
    --navy-950: #082f49;

    /* Extended neutrals */
    --slate-50: #f8fafc;
    --slate-100: #f1f5f9;
    --slate-200: #e2e8f0;
    --slate-300: #cbd5e1;
    --slate-400: #94a3b8;
    --slate-500: #64748b;
    --slate-600: #475569;
    --slate-700: #334155;
    --slate-800: #1e293b;
    --slate-900: #0f172a;
    --slate-950: #020617;

    /* Semantic tokens */
    --primary: var(--violet-600);
    --primary-hover: var(--violet-700);
    --primary-dark: var(--violet-700);
    --secondary: var(--fuchsia-500);
    --accent: var(--fuchsia-500);
    --accent-hover: var(--fuchsia-600);
    --warm-accent: var(--orange-500);
    --cool-accent: var(--cyan-400);
    --dark: var(--slate-950);
    --dark-light: var(--slate-900);
    --background: var(--slate-950);
    --background-light: var(--slate-900);
    --text: var(--slate-50);
    --text-muted: var(--slate-400);
    --success: var(--emerald-500);
    --border: rgba(255, 255, 255, 0.08);
  }

  .profile {
    min-height: 100vh;
    background: linear-gradient(135deg, #020617 0%, #0c4a6e 50%, #1e293b 100%);
  }

  .navbar {
    background: rgba(37, 37, 64, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(
      135deg,
      var(--primary) 0%,
      var(--secondary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .btn-back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: var(--primary);
  }

  .main-content {
    padding: 3rem 0;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;
    animation: fadeInUp 0.6s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .profile-icon {
    width: 96px;
    height: 96px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .email {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .organizer-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    border-radius: 20px;
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .section-header {
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .plan-type-badge {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: 20px;
    background: linear-gradient(
      135deg,
      rgba(16, 185, 129, 0.15) 0%,
      rgba(52, 211, 153, 0.15) 100%
    );
    border: 1.5px solid rgba(16, 185, 129, 0.4);
    color: var(--emerald-400);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .plan-type-badge.pro {
    background: linear-gradient(
      135deg,
      rgba(147, 51, 234, 0.2) 0%,
      rgba(217, 70, 239, 0.2) 100%
    );
    border-color: rgba(168, 85, 247, 0.5);
    color: var(--fuchsia-400);
  }

  .plan-header-price {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-left: 0.5rem;
  }

  .plan-section {
    margin-bottom: 3rem;
    animation: fadeInUp 0.6s ease 0.1s;
    animation-fill-mode: both;
  }

  .plan-card {
    background: rgba(37, 37, 64, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
  }

  .plan-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    gap: 1rem;
  }

  .stat-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .stat-content {
    flex: 1;
  }

  .stat-label {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .stat-value {
    color: var(--text);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .stat-max {
    color: var(--text-muted);
    font-size: 1.25rem;
  }

  .stat-bar {
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
    margin-top: 0.75rem;
  }

  .stat-bar-fill {
    height: 100%;
    background: linear-gradient(
      90deg,
      var(--primary) 0%,
      var(--secondary) 100%
    );
    border-radius: 3px;
    transition: width 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    width: 0;
  }

  .plan-actions {
    text-align: center;
  }

  .btn-upgrade {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    border: none;
    border-radius: 12px;
    color: white;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-upgrade:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.4);
  }

  .upgrade-benefits {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 1rem;
  }

  .info-section {
    background: rgba(37, 37, 64, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    animation: fadeInUp 0.6s ease 0.2s;
    animation-fill-mode: both;
  }

  .info-section h3 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .info-item {
    padding: 1rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
  }

  .info-item label {
    display: block;
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-item p {
    color: var(--text);
    font-size: 1rem;
    font-weight: 500;
    margin: 0;
  }

  @media (max-width: 768px) {
    .header h1 {
      font-size: 2rem;
    }

    .plan-stats {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function formatPrice(price: number): string {
    // Formato colombiano: punto como separador de miles
    const formatted = new Intl.NumberFormat("es-CO", {
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(price);

    return `$ ${formatted}`;
  }

  async function loadUserProfile() {
    try {
      console.log("Cargando estadísticas del plan...");
      const response = await fetch("/api/user/plan-stats");
      console.log("Response status:", response.status);

      const data = await response.json();
      console.log("Plan stats data:", data);

      if (!data.success) {
        console.error("Error en la respuesta:", data.error);
        // Mostrar error al usuario
        const planName = document.getElementById("plan-name");
        if (planName) {
          planName.textContent = "Error al cargar plan";
        }
        return;
      }

      if (data.success && data.stats) {
        const stats = data.stats;
        console.log("Stats:", stats);

        // Badge del tipo de plan en el título
        const planTypeBadge = document.getElementById("plan-type-badge");
        const planHeaderPrice = document.getElementById("plan-header-price");

        if (planTypeBadge) {
          planTypeBadge.textContent = stats.plan_name || "Gratuito";
          if (stats.plan_name === "PRO") {
            planTypeBadge.classList.add("pro");
          } else {
            planTypeBadge.classList.remove("pro");
          }
        }

        if (planHeaderPrice) {
          const price = stats.price || 0;
          planHeaderPrice.textContent = `${formatPrice(price)}/mes`;
        }

        // Eventos actuales
        const eventsCurrent = document.getElementById("events-current");
        const eventsMax = document.getElementById("events-max");
        const eventsBar = document.getElementById("events-bar");

        if (eventsCurrent && eventsMax && eventsBar) {
          eventsCurrent.textContent = stats.current_events_this_month || 0;

          if (stats.max_events_per_month === null) {
            eventsMax.textContent = "/ ∞";
            eventsBar.style.width = "100%";
          } else {
            eventsMax.textContent = `/ ${stats.max_events_per_month}`;
            const percentage =
              (stats.current_events_this_month / stats.max_events_per_month) *
              100;
            eventsBar.style.width = `${Math.min(percentage, 100)}%`;

            if (percentage >= 100) {
              eventsBar.style.background =
                "linear-gradient(90deg, #e74c3c 0%, #c0392b 100%)";
            } else if (percentage >= 80) {
              eventsBar.style.background =
                "linear-gradient(90deg, #f39c12 0%, #e67e22 100%)";
            }
          }
        }

        // Capacidad máxima
        const capacityMax = document.getElementById("capacity-max");
        if (capacityMax) {
          capacityMax.textContent =
            stats.max_capacity_per_event === null
              ? "Ilimitada"
              : `Máx ${stats.max_capacity_per_event} personas`;
        }

        // Eventos destacados
        const featuredStatus = document.getElementById("featured-status");
        if (featuredStatus) {
          featuredStatus.textContent = stats.can_feature_events
            ? "Disponible"
            : "No disponible";

          if (
            stats.can_feature_events &&
            featuredStatus.parentElement?.parentElement
          ) {
            featuredStatus.parentElement.parentElement.style.borderColor =
              "rgba(78, 205, 196, 0.3)";
            featuredStatus.parentElement.parentElement.style.background =
              "rgba(78, 205, 196, 0.1)";
          }
        }

        // Botón de upgrade
        const upgradeBtn = document.getElementById("upgrade-btn");
        const upgradeBenefits = document.getElementById("upgrade-benefits");

        if (
          stats.plan_name &&
          (stats.plan_name.toLowerCase() === "free" ||
            stats.plan_name.toLowerCase() === "gratuito")
        ) {
          if (upgradeBtn) upgradeBtn.style.display = "inline-flex";
          if (upgradeBenefits) upgradeBenefits.style.display = "block";

          upgradeBtn?.addEventListener("click", () => {
            window.location.href = "/checkout?plan=pro";
          });
        }
      } else {
        console.log("No hay stats disponibles");
        const planName = document.getElementById("plan-name");
        if (planName) {
          planName.textContent = "Plan no disponible";
        }
      }
    } catch (error) {
      console.error("Error loading profile:", error);
      const planName = document.getElementById("plan-name");
      if (planName) {
        planName.textContent = "Error al cargar";
      }
    }
  }

  // Formatear fecha de miembro
  const memberSince = document.getElementById("member-since");
  if (memberSince) {
    const date = new Date();
    memberSince.textContent = date.toLocaleDateString("es-ES", {
      year: "numeric",
      month: "long",
    });
  }

  loadUserProfile();
</script>
