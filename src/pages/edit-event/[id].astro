---
import Layout from "../../layouts/Layout.astro";
import EventImageUpload from "../../components/EventImageUpload.astro";
import { getUser } from "../../lib/auth";
import { supabase } from "../../lib/supabase";
import "leaflet/dist/leaflet.css";

const user = await getUser(Astro.cookies);

if (!user) {
  return Astro.redirect("/login");
}

const isOrganizer = user.user_metadata?.is_organizer || false;

if (!isOrganizer) {
  return Astro.redirect("/dashboard");
}

// Get event ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

// Fetch event from database
const { data: event, error } = await supabase
  .from("events")
  .select("*")
  .eq("id", id)
  .single();

if (error || !event) {
  console.error("Error fetching event:", error);
  return Astro.redirect("/dashboard");
}

// Verify user is the owner
if (event.organizer_id !== user.id) {
  return Astro.redirect("/dashboard");
}

// Fetch ALL images from event_images table (ordered by display_order)
const { data: eventImages } = await supabase
  .from("event_images")
  .select("id, image_url, is_primary, display_order")
  .eq("event_id", id)
  .order("display_order", { ascending: true });

// Add image_url to event object for compatibility (primary image)
const primaryImage = eventImages?.find((img) => img.is_primary);
event.image_url = primaryImage?.image_url || null;
event.all_images = eventImages || [];

// Format dates for datetime-local input
const formatDateForInput = (date: string | null) => {
  if (!date) return "";
  const d = new Date(date);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  const hours = String(d.getHours()).padStart(2, "0");
  const minutes = String(d.getMinutes()).padStart(2, "0");
  return `${year}-${month}-${day}T${hours}:${minutes}`;
};
---

<Layout title="Editar Evento">
  <div class="create-event-container">
    <nav class="navbar">
      <div class="nav-container">
        <a href="/dashboard" class="logo">EventHub</a>
        <a href="/dashboard" class="btn-back">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path
              d="M12 4l-6 6 6 6"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
          <span>Volver</span>
        </a>
      </div>
    </nav>

    <main class="main-content">
      <div class="container">
        <div class="header">
          <h1>Editar Evento</h1>
          <p class="subtitle">Actualiza la información de tu evento</p>
        </div>

        <div class="plan-warning" id="plan-warning" style="display: none;">
          <div class="warning-icon">⚠️</div>
          <div class="warning-content">
            <strong id="warning-title">Límite de plan</strong>
            <p id="warning-message">Cargando información del plan...</p>
          </div>
          <button class="btn-upgrade-inline" id="upgrade-inline"
            >Actualizar a PRO</button
          >
        </div>

        <form id="create-event-form" data-event-id={event.id}>
          <div class="form-card">
            <h2 class="section-title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path
                  d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
              Información Básica
            </h2>

            <div class="form-row">
              <div class="form-group full">
                <label for="title">Nombre del evento *</label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  placeholder="ej: Festival de Música Electrónica"
                  value={event.title}
                  required
                />
                <span class="error-message" id="title-error"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group full">
                <label for="description">Descripción</label>
                <textarea
                  id="description"
                  name="description"
                  rows="4"
                  placeholder="Describe tu evento, qué pueden esperar los asistentes..."
                  >{event.description || ""}</textarea
                >
                <span class="error-message" id="description-error"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="category">Categoría *</label>
                <select id="category" name="category" required>
                  <option value="">Selecciona una categoría</option>
                  <option
                    value="concert"
                    selected={event.category === "concert"}>Concierto</option
                  >
                  <option value="party" selected={event.category === "party"}
                    >Fiesta</option
                  >
                  <option value="sports" selected={event.category === "sports"}
                    >Deportes</option
                  >
                  <option
                    value="workshop"
                    selected={event.category === "workshop"}
                    >Taller/Workshop</option
                  >
                  <option
                    value="networking"
                    selected={event.category === "networking"}
                    >Networking</option
                  >
                  <option
                    value="conference"
                    selected={event.category === "conference"}
                    >Conferencia</option
                  >
                  <option
                    value="exhibition"
                    selected={event.category === "exhibition"}
                    >Exposición</option
                  >
                  <option
                    value="theater"
                    selected={event.category === "theater"}>Teatro</option
                  >
                  <option value="other" selected={event.category === "other"}
                    >Otro</option
                  >
                </select>
                <span class="error-message" id="category-error"></span>
              </div>

              <div class="form-group">
                <label for="capacity">Capacidad (opcional)</label>
                <input
                  type="number"
                  id="capacity"
                  name="capacity"
                  placeholder="ej: 100"
                  min="1"
                  value={event.capacity || ""}
                />
                <small class="help-text" id="capacity-help"
                  >Sin límite establecido</small
                >
                <span class="error-message" id="capacity-error"></span>
              </div>
            </div>
          </div>

          <div class="form-card">
            <h2 class="section-title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <rect
                  x="3"
                  y="4"
                  width="18"
                  height="18"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="2"></rect>
                <line
                  x1="16"
                  y1="2"
                  x2="16"
                  y2="6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></line>
                <line
                  x1="8"
                  y1="2"
                  x2="8"
                  y2="6"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></line>
                <line
                  x1="3"
                  y1="10"
                  x2="21"
                  y2="10"
                  stroke="currentColor"
                  stroke-width="2"></line>
              </svg>
              Fecha y Hora
            </h2>

            <div class="form-row">
              <div class="form-group">
                <label for="start_date">Fecha y hora de inicio *</label>
                <input
                  type="datetime-local"
                  id="start_date"
                  name="start_date"
                  value={formatDateForInput(event.start_date)}
                  required
                />
                <span class="error-message" id="start_date-error"></span>
              </div>

              <div class="form-group">
                <label for="end_date">Fecha y hora de fin (opcional)</label>
                <input
                  type="datetime-local"
                  id="end_date"
                  name="end_date"
                  value={formatDateForInput(event.end_date)}
                />
                <span class="error-message" id="end_date-error"></span>
              </div>
            </div>
          </div>

          <div class="form-card">
            <h2 class="section-title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path
                  d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                  stroke="currentColor"
                  stroke-width="2"></path>
                <circle
                  cx="12"
                  cy="10"
                  r="3"
                  stroke="currentColor"
                  stroke-width="2"></circle>
              </svg>
              Ubicación
            </h2>

            <div class="form-row">
              <div class="form-group">
                <label for="location_name">Nombre del lugar</label>
                <input
                  type="text"
                  id="location_name"
                  name="location_name"
                  placeholder="ej: Teatro Nacional"
                  value={event.location_name || ""}
                />
                <span class="error-message" id="location_name-error"></span>
              </div>

              <div class="form-group">
                <label for="city">Ciudad *</label>
                <input
                  type="text"
                  id="city"
                  name="city"
                  placeholder="ej: Bogotá"
                  value={event.city}
                  required
                />
                <span class="error-message" id="city-error"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group full">
                <label for="address">Dirección completa</label>
                <div class="address-input-group">
                  <input
                    type="text"
                    id="address"
                    name="address"
                    placeholder="ej: Calle 45 #12-34, Chapinero"
                    value={event.address || ""}
                  />
                  <button type="button" class="btn-geocode" id="geocode-btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M12 2L12 6M12 18L12 22M22 12L18 12M6 12L2 12M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                    Obtener coordenadas
                  </button>
                </div>
                <span class="error-message" id="address-error"></span>
              </div>
            </div>

            <!-- Interactive Map -->
            <div id="map-container" style="display: none; margin-top: 1rem;">
              <div
                style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.5rem;"
              >
                <label style="font-weight: 500; color: var(--text);">
                  📍 Ajusta la ubicación en el mapa
                </label>
                <button type="button" id="reset-map-btn" class="btn-reset-map">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                    <path
                      d="M21 3v5h-5M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                    <path
                      d="M8 16H3v5"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"></path>
                  </svg>
                  Recentrar
                </button>
              </div>
              <div
                id="location-map"
                style="height: 350px; border-radius: 12px; overflow: hidden; border: 1px solid var(--border);"
              >
              </div>
              <small
                id="reverse-geocode-status"
                style="display: none; margin-top: 0.5rem; color: var(--orange-500); font-style: italic;"
              >
                🔄 Obteniendo dirección...
              </small>
              <small
                style="display: block; margin-top: 0.5rem; color: var(--text-muted);"
              >
                💡 Arrastra el marcador o haz clic en el mapa para ajustar la
                ubicación
              </small>
            </div>

            <input
              type="hidden"
              id="latitude"
              name="latitude"
              value={event.latitude || ""}
            />
            <input
              type="hidden"
              id="longitude"
              name="longitude"
              value={event.longitude || ""}
            />
          </div>

          <div class="form-card">
            <EventImageUpload
              existingImages={event.all_images}
              maxImages={10}
            />
          </div>

          <div class="form-card">
            <h2 class="section-title">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <line
                  x1="12"
                  y1="1"
                  x2="12"
                  y2="23"
                  stroke="currentColor"
                  stroke-width="2"></line>
                <path
                  d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                  stroke="currentColor"
                  stroke-width="2"></path>
              </svg>
              Precio
            </h2>

            <div class="form-row">
              <div class="form-group checkbox-group">
                <label class="checkbox-label">
                  <input
                    type="checkbox"
                    name="is_free"
                    id="is_free"
                    checked={event.is_free}
                  />
                  <span>Evento gratuito</span>
                </label>
              </div>
            </div>

            <div class="form-row" id="price-row">
              <div class="form-group">
                <label for="price">Precio de entrada (COP)</label>
                <input
                  type="number"
                  id="price"
                  name="price"
                  placeholder="ej: 50000"
                  min="0"
                  step="1000"
                  value={event.price || 0}
                />
                <span class="error-message" id="price-error"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="form-group checkbox-group">
                <label class="checkbox-label" id="featured-label">
                  <input
                    type="checkbox"
                    name="is_featured"
                    id="is_featured"
                    checked={event.is_featured}
                    disabled
                  />
                  <span
                    >Marcar como evento destacado
                    <span class="pro-badge">PRO</span>
                  </span>
                </label>
                <small class="help-text"
                  >Los eventos destacados aparecen primero en la búsqueda</small
                >
              </div>
            </div>
          </div>

          <div class="error-message general" id="general-error"></div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">
              <span>Actualizar evento</span>
              <svg
                class="arrow"
                width="20"
                height="20"
                viewBox="0 0 20 20"
                fill="none"
              >
                <path
                  d="M4 10h12m0 0l-4-4m4 4l-4 4"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path>
              </svg>
            </button>
          </div>
        </form>

        <div class="success-message" id="success-message"></div>
      </div>
    </main>
  </div>
</Layout>

<style>
  :root {
    /* Violet - Primary brand */
    --violet-50: #faf5ff;
    --violet-100: #f3e8ff;
    --violet-200: #e9d5ff;
    --violet-300: #d8b4fe;
    --violet-400: #c084fc;
    --violet-500: #a855f7;
    --violet-600: #9333ea;
    --violet-700: #7e22ce;
    --violet-800: #6b21a8;
    --violet-900: #581c87;
    --violet-950: #3b0764;

    /* Fuchsia/Magenta - Energetic accent */
    --fuchsia-50: #fdf4ff;
    --fuchsia-100: #fae8ff;
    --fuchsia-200: #f5d0fe;
    --fuchsia-300: #f0abfc;
    --fuchsia-400: #e879f9;
    --fuchsia-500: #d946ef;
    --fuchsia-600: #c026d3;
    --fuchsia-700: #a21caf;
    --fuchsia-800: #86198f;
    --fuchsia-900: #701a75;

    /* Orange/Coral - Warm energy */
    --orange-50: #fff7ed;
    --orange-100: #ffedd5;
    --orange-200: #fed7aa;
    --orange-300: #fdba74;
    --orange-400: #fb923c;
    --orange-500: #f97316;
    --orange-600: #ea580c;
    --orange-700: #c2410c;
    --orange-800: #9a3412;
    --orange-900: #7c2d12;

    /* Cyan - Cool highlight */
    --cyan-50: #ecfeff;
    --cyan-100: #cffafe;
    --cyan-200: #a5f3fc;
    --cyan-300: #67e8f9;
    --cyan-400: #22d3ee;
    --cyan-500: #06b6d4;
    --cyan-600: #0891b2;
    --cyan-700: #0e7490;
    --cyan-800: #155e75;
    --cyan-900: #164e63;

    /* Emerald/Green - Success & Growth */
    --emerald-50: #ecfdf5;
    --emerald-100: #d1fae5;
    --emerald-200: #a7f3d0;
    --emerald-300: #6ee7b7;
    --emerald-400: #34d399;
    --emerald-500: #10b981;
    --emerald-600: #059669;
    --emerald-700: #047857;
    --emerald-800: #065f46;
    --emerald-900: #064e3b;

    /* Deep Blue/Navy - Professional dark */
    --navy-50: #f0f9ff;
    --navy-100: #e0f2fe;
    --navy-200: #bae6fd;
    --navy-300: #7dd3fc;
    --navy-400: #38bdf8;
    --navy-500: #0ea5e9;
    --navy-600: #0284c7;
    --navy-700: #0369a1;
    --navy-800: #075985;
    --navy-900: #0c4a6e;
    --navy-950: #082f49;

    /* Extended neutrals */
    --slate-50: #f8fafc;
    --slate-100: #f1f5f9;
    --slate-200: #e2e8f0;
    --slate-300: #cbd5e1;
    --slate-400: #94a3b8;
    --slate-500: #64748b;
    --slate-600: #475569;
    --slate-700: #334155;
    --slate-800: #1e293b;
    --slate-900: #0f172a;
    --slate-950: #020617;

    /* Semantic tokens */
    --primary: var(--violet-600);
    --primary-hover: var(--violet-700);
    --primary-dark: var(--violet-700);
    --secondary: var(--fuchsia-500);
    --accent: var(--fuchsia-500);
    --accent-hover: var(--fuchsia-600);
    --warm-accent: var(--orange-500);
    --cool-accent: var(--cyan-400);
    --dark: var(--slate-950);
    --dark-light: var(--slate-900);
    --background: var(--slate-950);
    --background-light: var(--slate-900);
    --text: var(--slate-50);
    --text-muted: var(--slate-400);
    --success: var(--emerald-500);
    --border: rgba(255, 255, 255, 0.08);
  }

  .create-event-container {
    min-height: 100vh;
    background: linear-gradient(135deg, #020617 0%, #0c4a6e 50%, #1e293b 100%);
  }

  .navbar {
    background: rgba(37, 37, 64, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.5rem;
    font-weight: 800;
    background: linear-gradient(
      135deg,
      var(--primary) 0%,
      var(--secondary) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .btn-back {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: var(--primary);
  }

  .main-content {
    padding: 3rem 0;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;
    animation: fadeInUp 0.6s ease;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.1rem;
  }

  .form-card {
    background: rgba(37, 37, 64, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease;
    animation-fill-mode: both;
  }

  .form-card:nth-child(2) {
    animation-delay: 0.1s;
  }

  .form-card:nth-child(3) {
    animation-delay: 0.2s;
  }

  .form-card:nth-child(4) {
    animation-delay: 0.3s;
  }

  .form-card:nth-child(5) {
    animation-delay: 0.4s;
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title svg {
    color: var(--primary);
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .form-row:last-child {
    margin-bottom: 0;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group.full {
    grid-column: 1 / -1;
  }

  label {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--text);
    font-weight: 500;
    font-size: 0.9rem;
  }

  input[type="text"],
  input[type="number"],
  input[type="datetime-local"],
  select,
  textarea {
    width: 100%;
    padding: 0.875rem 1rem;
    background: rgba(0, 0, 0, 0.3);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-size: 1rem;
    font-family: "Outfit", system-ui, sans-serif;
    transition: all 0.3s ease;
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
    background: rgba(0, 0, 0, 0.4);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.1);
  }

  input.error,
  select.error,
  textarea.error {
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }

  input.error:focus,
  select.error:focus,
  textarea.error:focus {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  input::placeholder,
