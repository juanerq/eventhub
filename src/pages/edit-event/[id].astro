</style>

<script>
  import {
    geocodeAddress,
    reverseGeocodeDetailed,
  } from "../../lib/geolocation";
  // @ts-ignore - Leaflet types are for client-side only
  import L from "leaflet";

  // Fix Leaflet default icon path issues
  delete (L.Icon.Default.prototype as any)._getIconUrl;
  L.Icon.Default.mergeOptions({
    iconRetinaUrl:
      "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon-2x.png",
    iconUrl:
      "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-icon.png",
    shadowUrl:
      "https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/images/marker-shadow.png",
  });

  // Geocode button handler
  const geocodeBtn = document.getElementById("geocode-btn");
  const locationNameInput = document.getElementById(
    "location_name",
  ) as HTMLInputElement;
  const addressInput = document.getElementById("address") as HTMLInputElement;
  const cityInput = document.getElementById("city") as HTMLInputElement;
  const latitudeInput = document.getElementById("latitude") as HTMLInputElement;
  const longitudeInput = document.getElementById(
    "longitude",
  ) as HTMLInputElement;
  const mapContainer = document.getElementById("map-container");
  const resetMapBtn = document.getElementById("reset-map-btn");

  // Map variables
  let map: L.Map | null = null;
  let marker: L.Marker | null = null;
  let initialCoords: { lat: number; lng: number } | null = null;

  // Initialize interactive map
  function initializeMap(lat: number, lng: number) {
    const mapElement = document.getElementById("location-map");
    if (!mapElement) return;

    // Store initial coordinates
    initialCoords = { lat, lng };

    // Clear existing map if any
    if (map) {
      map.remove();
    }

    // Create map
    map = L.map("location-map").setView([lat, lng], 16);

    // Add tile layer (OpenStreetMap)
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      attribution: "© OpenStreetMap contributors",
      maxZoom: 19,
    }).addTo(map);

    // Add draggable marker
    marker = L.marker([lat, lng], {
      draggable: true,
      autoPan: true,
    }).addTo(map);

    // Add popup to marker
    marker
      .bindPopup(
        `
      <div style="text-align: center; padding: 0.5rem;">
        <strong style="color: var(--violet-600);">📍 Ubicación del evento</strong><br/>
        <small style="color: var(--text-muted);">Arrastra para ajustar</small>
      </div>
    `,
      )
      .openPopup();

    // Update coordinates when marker is dragged
    marker.on("dragend", function (event: any) {
      const position = event.target.getLatLng();
      updateCoordinates(position.lat, position.lng);
    });

    // Update coordinates when clicking on map
    map.on("click", function (event: any) {
      const { lat, lng } = event.latlng;
      if (marker) {
        marker.setLatLng([lat, lng]);
        updateCoordinates(lat, lng);
      }
    });

    // Show map container
    if (mapContainer) {
      mapContainer.style.display = "block";
      // Force Leaflet to recalculate map size after showing container
      setTimeout(() => {
        if (map) {
          map.invalidateSize();
        }
      }, 100);
    }
  }

  // Update coordinates display and reverse geocode
  async function updateCoordinates(lat: number, lng: number) {
    // Update coordinates
    if (latitudeInput) latitudeInput.value = lat.toString();
    if (longitudeInput) longitudeInput.value = lng.toString();

    // Show loading indicator
    const statusElement = document.getElementById("reverse-geocode-status");
    if (statusElement) {
      statusElement.style.display = "block";
    }

    // Reverse geocode to get address
    try {
      const result = await reverseGeocodeDetailed(lat, lng);
      if (result) {
        // Update form fields with new address (always update, even if empty)
        if (locationNameInput) {
          // Only update if we have a meaningful location name
          if (result.locationName) {
            locationNameInput.value = result.locationName;
          }
        }
        // Always update city and address to ensure consistency
        if (cityInput) {
          cityInput.value = result.city || "";
        }
        if (addressInput) {
          addressInput.value = result.address || "";
        }
      }
    } catch (error) {
      console.error("Error al obtener dirección:", error);
    } finally {
      // Hide loading indicator after 500ms
      if (statusElement) {
        setTimeout(() => {
          statusElement.style.display = "none";
        }, 500);
      }
    }
  }

  // Reset map to initial coordinates
  resetMapBtn?.addEventListener("click", () => {
    if (map && marker && initialCoords) {
      map.setView([initialCoords.lat, initialCoords.lng], 16);
      marker.setLatLng([initialCoords.lat, initialCoords.lng]);
      updateCoordinates(initialCoords.lat, initialCoords.lng);
    }
  });

  // Show existing coordinates if available
  if (latitudeInput?.value && longitudeInput?.value) {
    const lat = parseFloat(latitudeInput.value);
    const lng = parseFloat(longitudeInput.value);

    if (geocodeBtn) {
      geocodeBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Coordenadas obtenidas
      `;
    }

    // Show map with existing coordinates
    if (!isNaN(lat) && !isNaN(lng)) {
      initializeMap(lat, lng);
    }
  }

  // Function to reset geocode button when address changes
  function resetGeocodeButton() {
    if (geocodeBtn) {
      geocodeBtn.removeAttribute("disabled");
      geocodeBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L12 6M12 18L12 22M22 12L18 12M6 12L2 12M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" 
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Obtener coordenadas
      `;
    }
    // Don't hide map - let user continue adjusting manually
  }

  // Listen for changes in geocoding-relevant inputs
  locationNameInput?.addEventListener("input", resetGeocodeButton);
  addressInput?.addEventListener("input", resetGeocodeButton);
  cityInput?.addEventListener("input", resetGeocodeButton);

  geocodeBtn?.addEventListener("click", async () => {
    const address = addressInput?.value.trim();
    const city = cityInput?.value.trim();

    if (!address && !city) {
      alert("Por favor ingresa al menos una dirección o ciudad");
      return;
    }

    // Warn user if address is too generic
    const isGenericTerm =
      address && /^(parque|plaza|iglesia|centro|estadio)$/i.test(address);

    geocodeBtn.setAttribute("disabled", "true");
    geocodeBtn.innerHTML = `
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="spinner">
        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" opacity="0.25"/>
        <path d="M12 2 A10 10 0 0 1 22 12" stroke="currentColor" stroke-width="2" fill="none"/>
      </svg>
      Buscando...
    `;

    // Use improved geocoding with structured search
    const coordinates = await geocodeAddress(address || "", city, "Colombia");

    if (coordinates) {
      latitudeInput.value = coordinates.latitude.toString();
      longitudeInput.value = coordinates.longitude.toString();

      geocodeBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Coordenadas obtenidas
      `;

      // Initialize interactive map
      initializeMap(coordinates.latitude, coordinates.longitude);
    } else {
      let errorMessage = "No se encontró la ubicación.";

      if (isGenericTerm) {
        errorMessage += ` El término "${address}" es muy genérico. Intenta agregar más detalles como:\n- "${address} principal"\n- "${address} de la ciudad"\n- Una dirección específica`;
      } else if (!city) {
        errorMessage += " Por favor especifica la ciudad.";
      } else {
        errorMessage += ` Verifica que la dirección exista en ${city}.`;
      }

      alert(errorMessage);
      geocodeBtn.removeAttribute("disabled");
      geocodeBtn.innerHTML = `
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
          <path d="M12 2L12 6M12 18L12 22M22 12L18 12M6 12L2 12M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" 
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Obtener coordenadas
      `;
    }
  });

  const form = document.getElementById("create-event-form");
  const isFreeCheckbox = document.getElementById("is_free") as HTMLInputElement;
  const priceRow = document.getElementById("price-row");
  const priceInput = document.getElementById("price") as HTMLInputElement;

  let planStats: any = null;

  // Cargar estadísticas del plan
  async function loadPlanStats() {
    try {
      const response = await fetch("/api/user/plan-stats");
      const data = await response.json();

      if (data.success && data.stats) {
        planStats = data.stats;
        updateUIWithPlanLimits();
      }
    } catch (error) {
      console.error("Error loading plan stats:", error);
    }
  }

  function updateUIWithPlanLimits() {
    if (!planStats) return;

    // Actualizar límite de capacidad
    const capacityInput = document.getElementById(
      "capacity",
    ) as HTMLInputElement;
    const capacityHelp = document.getElementById("capacity-help");

    if (
      capacityInput &&
      capacityHelp &&
      planStats.max_capacity_per_event !== null
    ) {
      capacityInput.max = planStats.max_capacity_per_event;
      capacityHelp.textContent = `Máximo ${planStats.max_capacity_per_event} personas para tu plan`;
    } else if (capacityHelp) {
      capacityHelp.textContent = "Sin límite de capacidad";
    }

    // Habilitar/deshabilitar eventos destacados
    const featuredCheckbox = document.getElementById(
      "is_featured",
    ) as HTMLInputElement;
    if (featuredCheckbox) {
      if (planStats.can_feature_events) {
        featuredCheckbox.disabled = false;
      } else {
        featuredCheckbox.disabled = true;
        featuredCheckbox.checked = false;
      }
    }

    // Mostrar advertencia si está cerca del límite de eventos
    const planWarning = document.getElementById("plan-warning");
    const warningTitle = document.getElementById("warning-title");
    const warningMessage = document.getElementById("warning-message");

    if (planStats.max_events_per_month !== null) {
      const eventsUsed = planStats.current_events_this_month || 0;
      const eventsMax = planStats.max_events_per_month;
      const eventsRemaining = eventsMax - eventsUsed;

      if (eventsRemaining <= 0) {
        planWarning!.style.display = "flex";
        warningTitle!.textContent = "❌ Has alcanzado tu límite";
        warningMessage!.textContent = `Has creado ${eventsUsed}/${eventsMax} eventos este mes. Actualiza a PRO para eventos ilimitados.`;

        // Deshabilitar el formulario
        const submitBtn = form?.querySelector(
          'button[type="submit"]',
        ) as HTMLButtonElement;
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = "Límite alcanzado";
        }
      } else if (eventsRemaining <= 1) {
        planWarning!.style.display = "flex";
        warningTitle!.textContent = "⚠️ Último evento disponible";
        warningMessage!.textContent = `Te queda ${eventsRemaining} evento${eventsRemaining === 1 ? "" : "s"} de ${eventsMax} este mes. Considera actualizar a PRO.`;
      }
    }

    // Actualizar stats del imageHandler
    if (imageHandler) {
      imageHandler.setPlanStats(planStats);
    }

    // Configurar botón de upgrade
    const upgradeBtn = document.getElementById("upgrade-inline");
    upgradeBtn?.addEventListener("click", () => {
      alert(
        "Próximamente: Actualizar a PRO por $20.000.000/mes\n\n✨ Eventos ilimitados\n✨ Capacidad ilimitada\n✨ Eventos destacados",
      );
    });
  }

  // Validar límites al enviar
  function validatePlanLimits(): boolean {
    if (!planStats) return true;

    // Validar capacidad
    const capacityInput = document.getElementById(
      "capacity",
    ) as HTMLInputElement;
    if (capacityInput && capacityInput.value) {
      const capacity = parseInt(capacityInput.value);
      if (
        planStats.max_capacity_per_event !== null &&
        capacity > planStats.max_capacity_per_event
      ) {
        showError(
          "capacity",
          `La capacidad máxima para tu plan es ${planStats.max_capacity_per_event} personas`,
        );
        return false;
      }
    }

    // Validar eventos destacados
    const featuredCheckbox = document.getElementById(
      "is_featured",
    ) as HTMLInputElement;
    if (
      featuredCheckbox &&
      featuredCheckbox.checked &&
      !planStats.can_feature_events
    ) {
      showGeneralError("Solo los usuarios PRO pueden destacar eventos");
      return false;
    }

    return true;
  }

  // Cargar estadísticas al inicio
  loadPlanStats();

  // ============================================
  // MANEJO DE MÚLTIPLES IMÁGENES
  // ============================================
  // Manejo de imágenes con EventImageHandler
  // ============================================
  import { EventImageHandler } from "../../lib/eventImageHandler";

  // Primero definir las funciones de error
  function showError(inputId: string, message: string) {
    const input = document.getElementById(inputId);
    const errorElement = document.getElementById(inputId + "-error");

    if (input) {
      input.classList.add("error");
      input.focus();
    }
    if (errorElement) {
      errorElement.textContent = message;
    }
  }

  function clearAllErrors() {
    const inputs = form?.querySelectorAll("input, select, textarea");
    inputs?.forEach((input) => input.classList.remove("error"));

    const errorMessages = form?.querySelectorAll(".error-message");
    errorMessages?.forEach((msg) => (msg.textContent = ""));
  }

  // Ahora inicializar el EventImageHandler
  const imageHandler = new EventImageHandler({
    showError,
    clearErrors: clearAllErrors,
  });

  // Toggle price field based on "free" checkbox
  isFreeCheckbox?.addEventListener("change", () => {
    if (isFreeCheckbox.checked) {
      priceRow!.style.display = "none";
      priceInput.value = "0";
      priceInput.required = false;
    } else {
      priceRow!.style.display = "block";
      priceInput.required = false;
    }
  });

  // Clear errors on input
  function setupErrorClear() {
    const inputs = form?.querySelectorAll("input, select, textarea");
    inputs?.forEach((input) => {
      input.addEventListener("input", () => {
        input.classList.remove("error");
        const errorId = input.id + "-error";
        const errorElement = document.getElementById(errorId);
        if (errorElement) errorElement.textContent = "";
      });
    });
  }

  function showGeneralError(message: string) {
    const errorElement = document.getElementById("general-error");
    if (errorElement) {
      errorElement.textContent = message;
    }
  }

  function showSuccess(message: string) {
    const successElement = document.getElementById("success-message");
    if (successElement) {
      successElement.textContent = message;
      setTimeout(() => {
        window.location.href = "/dashboard";
      }, 2000);
    }
  }

  async function submitEvent() {
    clearAllErrors();

    // Validar límites del plan antes de enviar
    if (!validatePlanLimits()) {
      return;
    }

    const formData = new FormData(form as HTMLFormElement);

    // Eliminar el campo event_images que viene del form (evitar duplicados)
    formData.delete("event_images");

    // Obtener archivos del imageHandler
    const newFiles = imageHandler.getFiles();
    const imagesToRemove = imageHandler.getImagesToRemove();

    console.log("📸 Nuevas imágenes a subir:", newFiles.length);
    console.log("🗑️ Imágenes a eliminar:", imagesToRemove);

    // Agregar las nuevas imágenes al FormData
    newFiles.forEach((file) => {
      formData.append("event_images", file);
    });

    // Agregar IDs de imágenes a eliminar
    if (imagesToRemove.length > 0) {
      formData.append("images_to_remove", imagesToRemove.join(","));
    }

    // Add event ID
    const eventId = form?.getAttribute("data-event-id");
    if (eventId) {
      formData.append("id", eventId);
    }

    // Add status as published
    formData.set("status", "published");

    // Ensure is_free is set correctly
    const isFreeCheckbox = document.getElementById(
      "is_free",
    ) as HTMLInputElement;
    formData.set("is_free", isFreeCheckbox?.checked ? "true" : "false");

    // If is_free is true, set price to 0
    if (isFreeCheckbox?.checked) {
      formData.set("price", "0");
    }

    const submitBtn = (form as HTMLFormElement).querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;

    const originalText = submitBtn.innerHTML;
    submitBtn.innerHTML = "<span>Actualizando...</span>";
    submitBtn.disabled = true;

    try {
      const response = await fetch("/api/events/update", {
        method: "POST",
        body: formData, // Send FormData directly, no Content-Type header needed
      });

      const result = await response.json();

      if (result.success) {
        showSuccess("¡Evento actualizado exitosamente! Redirigiendo...");
      } else {
        showGeneralError(result.error || "Error al actualizar el evento");
        submitBtn.innerHTML = originalText;
        submitBtn.disabled = false;
      }
    } catch (error) {
      console.error("Error:", error);
      showGeneralError("Error de conexión. Por favor intenta nuevamente.");
      submitBtn.innerHTML = originalText;
      submitBtn.disabled = false;
    }
  }

  setupErrorClear();

  // Handle form submit (publish)
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    await submitEvent();
  });
</script>
