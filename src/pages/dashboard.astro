<script>
  // Leaflet is loaded from CDN as a global variable
  declare const L: any;

  // Wait for Leaflet to be available
  function waitForLeaflet(): Promise<void> {
    return new Promise((resolve) => {
      if (typeof L !== "undefined") {
        resolve();
      } else {
        const checkInterval = setInterval(() => {
          if (typeof L !== "undefined") {
            clearInterval(checkInterval);
            console.log("Leaflet loaded successfully");
            resolve();
          }
        }, 100);

        // Timeout after 5 seconds
        setTimeout(() => {
          clearInterval(checkInterval);
          console.error("Leaflet failed to load");
          resolve();
        }, 5000);
      }
    });
  }

  // ===== Geolocation Utilities =====

  /**
   * Calculate distance between two coordinates using Haversine formula
   */
  function calculateDistance(
    lat1: number,
    lon1: number,
    lat2: number,
    lon2: number,
  ): number {
    const R = 6371; // Earth's radius in kilometers
    const dLat = toRadians(lat2 - lat1);
    const dLon = toRadians(lon2 - lon1);

    const a =
      Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos(toRadians(lat1)) *
        Math.cos(toRadians(lat2)) *
        Math.sin(dLon / 2) *
        Math.sin(dLon / 2);

    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    const distance = R * c;

    return Math.round(distance * 10) / 10; // Round to 1 decimal
  }

  function toRadians(degrees: number): number {
    return degrees * (Math.PI / 180);
  }

  async function getUserLocation(): Promise<{
    latitude: number;
    longitude: number;
  } | null> {
    return new Promise((resolve) => {
      if (!navigator.geolocation) {
        console.warn("Geolocation not supported");
        alert("Tu navegador no soporta geolocalización");
        resolve(null);
        return;
      }

      navigator.geolocation.getCurrentPosition(
        (position) => {
          resolve({
            latitude: position.coords.latitude,
            longitude: position.coords.longitude,
          });
        },
        (error) => {
          console.warn("Geolocation error:", error.message, error.code);

          // Show user-friendly error messages
          let errorMessage = "No se pudo obtener tu ubicación. ";

          switch (error.code) {
            case error.PERMISSION_DENIED:
              errorMessage +=
                "Has denegado el permiso de ubicación. Por favor, permite el acceso en la configuración de tu navegador.";
              break;
            case error.POSITION_UNAVAILABLE:
              errorMessage += "La información de ubicación no está disponible.";
              break;
            case error.TIMEOUT:
              errorMessage +=
                "Se agotó el tiempo de espera para obtener tu ubicación.";
              break;
            default:
              errorMessage += "Error desconocido.";
          }

          alert(errorMessage);
          resolve(null);
        },
        {
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 300000, // 5 minutes
        },
      );
    });
  }

  // ===== Logout Handler =====

  const logoutForm = document.querySelector('form[action="/api/auth/logout"]');
  logoutForm?.addEventListener("submit", async (e) => {
    e.preventDefault();

    try {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = "/login";
    } catch (error) {
      console.error("Logout error:", error);
      window.location.href = "/login";
    }
  });

  // Events functionality
  async function loadCategories() {
    try {
      const response = await fetch("/api/events/categories");
      const data = await response.json();

      if (data.categories && data.categories.length > 0) {
        const filtersContainer = document.getElementById("filters");

        if (filtersContainer) {
          // Mantener el botón "Todos" y agregar las categorías dinámicas
          const categoryButtons = data.categories
            .map((category: { id: string; name: string; icon: string }) => {
              return `<button class="filter-btn" data-category="${category.id}">
                <span class="filter-icon">${category.icon}</span>
                <span class="filter-text">${category.name}</span>
              </button>`;
            })
            .join("");

          // Agregar los botones después del botón "Todos"
          filtersContainer.innerHTML += categoryButtons;
        }
      }

      // Marcar el botón de categoría activo basándose en la URL
      const urlParams = new URLSearchParams(window.location.search);
      const activeCategory = urlParams.get("category") || "all";

      const categoryButtons = document.querySelectorAll(
        ".filter-btn[data-category]",
      );
      categoryButtons.forEach((btn) => {
        const btnCategory = (btn as HTMLElement).dataset.category || "all";
        if (btnCategory === activeCategory) {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });
    } catch (error) {
      console.error("Error loading categories:", error);
    }

    // Siempre configurar los event listeners, independientemente del resultado
    setupFilterListeners();
  }

  function setupFilterListeners() {
    const categoryButtons = document.querySelectorAll(
      ".filter-btn[data-category]",
    );
    const priceButtons = document.querySelectorAll(".filter-btn[data-price]");

    // Category filter buttons - cambiar categoría mediante URL
    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const category = (button as HTMLElement).dataset.category || "all";

        // Construir nueva URL con parámetro de categoría
        const url = new URL(window.location.href);
        if (category === "all") {
          url.searchParams.delete("category");
        } else {
          url.searchParams.set("category", category);
        }

        // Recargar página con nueva categoría
        window.location.href = url.toString();
      });
    });

    // Price filter buttons
    priceButtons.forEach((button) => {
      button.addEventListener("click", () => {
        priceButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        const price = (button as HTMLElement).dataset.price || "all";
        currentFilters.price = price;

        // Limpiar inputs de precio personalizado
        currentFilters.priceMin = "";
        currentFilters.priceMax = "";
        const priceMinInput = document.getElementById(
          "price-min",
        ) as HTMLInputElement;
        const priceMaxInput = document.getElementById(
          "price-max",
        ) as HTMLInputElement;
        if (priceMinInput) priceMinInput.value = "";
        if (priceMaxInput) priceMaxInput.value = "";

        applyFiltersAndRender();
      });
    });
  }

  // Variables globales para los filtros
  let currentFilters = {
    category: "all",
    search: "",
    dateFrom: "",
    dateTo: "",
    price: "all",
    priceMin: "",
    priceMax: "",
    sort: "date-asc",
    userLocation: null as { latitude: number; longitude: number } | null,
    distanceKm: 10,
  };

  function applyFiltersAndRender() {
    const eventsGrid = document.getElementById("events-grid");
    const emptyState = document.getElementById("events-empty");

    if (!eventsGrid) return;

    const allCardWrappers = eventsGrid.querySelectorAll(
      ".event-card-wrapper",
    ) as NodeListOf<HTMLElement>;
    let visibleCount = 0;

    allCardWrappers.forEach((wrapper) => {
      let isVisible = true;

      // Filtro de búsqueda
      if (currentFilters.search) {
        const searchLower = currentFilters.search.toLowerCase();
        const title = wrapper.dataset.title || "";
        const description = wrapper.dataset.description || "";
        const category = wrapper.dataset.category || "";
        const city = wrapper.dataset.city || "";
        const locationName = wrapper.dataset.locationName || "";

        isVisible =
          isVisible &&
          (title.includes(searchLower) ||
            description.includes(searchLower) ||
            category.includes(searchLower) ||
            city.includes(searchLower) ||
            locationName.includes(searchLower));
      }

      // Filtro de fecha por rango
      if (currentFilters.dateFrom || currentFilters.dateTo) {
        const eventDate = wrapper.dataset.startDate || "";
        const eventDateOnly = eventDate.split("T")[0];

        if (currentFilters.dateFrom) {
          isVisible = isVisible && eventDateOnly >= currentFilters.dateFrom;
        }

        if (currentFilters.dateTo) {
          isVisible = isVisible && eventDateOnly <= currentFilters.dateTo;
        }
      }

      // Filtro de precio
      const price = parseFloat(wrapper.dataset.price || "0");
      const isFree = wrapper.dataset.isFree === "true";

      if (
        currentFilters.price === "custom" &&
        (currentFilters.priceMin || currentFilters.priceMax)
      ) {
        const min = currentFilters.priceMin
          ? parseFloat(currentFilters.priceMin)
          : 0;
        const max = currentFilters.priceMax
          ? parseFloat(currentFilters.priceMax)
          : Infinity;

        if (isFree) {
          isVisible = isVisible && min === 0;
        } else {
          isVisible = isVisible && price >= min && price <= max;
        }
      } else if (currentFilters.price !== "all") {
        switch (currentFilters.price) {
          case "free":
            isVisible = isVisible && isFree;
            break;
          case "paid":
            isVisible = isVisible && !isFree;
            break;
          case "0-50000":
            isVisible = isVisible && price >= 0 && price <= 50000;
            break;
          case "50000-100000":
            isVisible = isVisible && price > 50000 && price <= 100000;
            break;
          case "100000+":
            isVisible = isVisible && price > 100000;
            break;
        }
      }

      // Filtro de ubicación
      if (currentFilters.userLocation && currentFilters.distanceKm) {
        const lat = wrapper.dataset.latitude;
        const lon = wrapper.dataset.longitude;

        if (lat && lon) {
          const distance = calculateDistance(
            currentFilters.userLocation.latitude,
            currentFilters.userLocation.longitude,
            parseFloat(lat),
            parseFloat(lon),
          );
          isVisible = isVisible && distance <= currentFilters.distanceKm;
        }
      }

      // Aplicar visibilidad
      wrapper.style.display = isVisible ? "" : "none";
      if (isVisible) visibleCount++;
    });

    // Ordenar elementos visibles
    const sortedWrappers = Array.from(allCardWrappers)
      .filter((w) => w.style.display !== "none")
      .sort((a, b) => {
        switch (currentFilters.sort) {
          case "date-asc":
            return (a.dataset.startDate || "").localeCompare(
              b.dataset.startDate || "",
            );
          case "date-desc":
            return (b.dataset.startDate || "").localeCompare(
              a.dataset.startDate || "",
            );
          case "price-asc":
            return (
              parseFloat(a.dataset.price || "0") -
              parseFloat(b.dataset.price || "0")
            );
          case "price-desc":
            return (
              parseFloat(b.dataset.price || "0") -
              parseFloat(a.dataset.price || "0")
            );
          case "name":
            return (a.dataset.title || "").localeCompare(b.dataset.title || "");
          default:
            return 0;
        }
      });

    // Reordenar en el DOM
    sortedWrappers.forEach((wrapper) => eventsGrid.appendChild(wrapper));

    // Mostrar/ocultar empty state
    if (emptyState) {
      emptyState.style.display = visibleCount === 0 ? "flex" : "none";
    }

    if (visibleCount === 0) {
      eventsGrid.style.display = "none";
    } else {
      eventsGrid.style.display = "grid";
    }
  }

  document.addEventListener("DOMContentLoaded", async () => {
    // Cargar categorías
    await loadCategories();

    // Configurar listeners
    setupFilterListeners();

    // Aplicar filtros iniciales (todos los eventos ya están renderados)
    applyFiltersAndRender();

    // Event listeners para filtros
    const searchInput = document.getElementById(
      "search-input",
    ) as HTMLInputElement;
    const dateFromInput = document.getElementById(
      "date-from",
    ) as HTMLInputElement;
    const dateToInput = document.getElementById("date-to") as HTMLInputElement;
    const priceMinInput = document.getElementById(
      "price-min",
    ) as HTMLInputElement;
    const priceMaxInput = document.getElementById(
      "price-max",
    ) as HTMLInputElement;
    const sortFilter = document.getElementById(
      "sort-filter",
    ) as HTMLSelectElement;

    // Location filter handlers
    const locationBtn = document.getElementById("get-user-location");
    const searchLocationInput = document.getElementById(
      "location-search-input",
    ) as HTMLInputElement;
    const searchLocationBtn = document.getElementById("search-location-btn");
    const distanceSelector = document.getElementById("distance-selector");
    const distanceRange = document.getElementById(
      "distance-range",
    ) as HTMLInputElement;
    const distanceValue = document.getElementById("distance-value");
    const locationStatus = document.getElementById("location-status");
    const locationInfo = document.getElementById("location-info");
    const mapContainer = document.getElementById("location-map");

    // Map variables
    let locationMap: any = null;
    let userMarker: any = null;
    let radiusCircle: any = null;
    let priceTimeout: any = null;

    // Initialize map with user location
    function initializeLocationMap(lat: number, lng: number, radiusKm: number) {
      console.log("Initializing map with:", lat, lng, radiusKm);
      console.log("Map container:", mapContainer);
      console.log("Leaflet L object:", typeof L);

      if (!mapContainer) {
        console.error("Map container not found!");
        return;
      }

      // Show map container
      mapContainer.style.display = "block";

      // Create map if not exists
      if (!locationMap) {
        console.log("Creating new map...");
        try {
          locationMap = L.map("location-map").setView([lat, lng], 12);
          console.log("Map created:", locationMap);
        } catch (error) {
          console.error("Error creating map:", error);
          return;
        }

        // Add OpenStreetMap tiles
        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          attribution: "© OpenStreetMap contributors",
          maxZoom: 19,
        }).addTo(locationMap);

        // Fix Leaflet default icon paths
        delete (L.Icon.Default.prototype as any)._getIconUrl;
        L.Icon.Default.mergeOptions({
          iconRetinaUrl:
            "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png",
          iconUrl:
            "https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png",
          shadowUrl:
            "https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png",
        });

        // Make map clickeable to set custom location
        locationMap.on("click", (e: any) => {
          const { lat, lng } = e.latlng;
          console.log("Map clicked at:", lat, lng);

          // Update marker position
          if (userMarker) {
            userMarker.setLatLng([lat, lng]);
          } else {
            userMarker = L.marker([lat, lng]).addTo(locationMap);
          }
          userMarker.bindPopup("📍 Ubicación seleccionada").openPopup();

          // Update radius circle
          if (radiusCircle) {
            radiusCircle.setLatLng([lat, lng]);
          } else {
            radiusCircle = L.circle([lat, lng], {
              color: "#9333ea",
              fillColor: "#9333ea",
              fillOpacity: 0.15,
              radius: currentFilters.distanceKm * 1000,
            }).addTo(locationMap);
          }

          // Update filters and apply
          currentFilters.userLocation = { latitude: lat, longitude: lng };
          if (locationInfo) locationInfo.style.display = "block";
          applyFiltersAndRender();
        });
      }

      // Add or update user marker
      if (userMarker) {
        userMarker.setLatLng([lat, lng]);
      } else {
        userMarker = L.marker([lat, lng]).addTo(locationMap);
        userMarker.bindPopup("Tu ubicación").openPopup();
      }

      // Add or update radius circle
      if (radiusCircle) {
        radiusCircle.setLatLng([lat, lng]);
        radiusCircle.setRadius(radiusKm * 1000); // Convert km to meters
      } else {
        radiusCircle = L.circle([lat, lng], {
          color: "#9333ea",
          fillColor: "#9333ea",
          fillOpacity: 0.15,
          radius: radiusKm * 1000, // Convert km to meters
        }).addTo(locationMap);
      }

      // Fit map to circle bounds with some padding
      locationMap.fitBounds(radiusCircle.getBounds(), { padding: [20, 20] });

      // Invalidate size to fix rendering issues
      setTimeout(() => {
        console.log("Invalidating map size...");
        locationMap?.invalidateSize();
      }, 100);
    }

    // Search location by address
    async function searchLocationByAddress(query: string) {
      if (!query.trim()) {
        alert("Por favor ingresa una ubicación para buscar");
        return null;
      }

      try {
        const response = await fetch(
          `https://nominatim.openstreetmap.org/search?` +
            `q=${encodeURIComponent(query)}&` +
            `format=json&` +
            `countrycodes=co&` +
            `addressdetails=1&` +
            `limit=1`,
          {
            headers: {
              "User-Agent": "EventHub-Location-Search",
            },
          },
        );

        if (!response.ok) {
          throw new Error("Error en la búsqueda");
        }

        const results = await response.json();

        if (results && results.length > 0) {
          const result = results[0];
          return {
            latitude: parseFloat(result.lat),
            longitude: parseFloat(result.lon),
            displayName: result.display_name,
          };
        } else {
          return null;
        }
      } catch (error) {
        console.error("Error searching location:", error);
        return null;
      }
    }

    // Search location button handler
    if (searchLocationBtn && searchLocationInput) {
      searchLocationBtn.addEventListener("click", async () => {
        const query = searchLocationInput.value.trim();

        if (!query) {
          alert("Por favor ingresa una ciudad, dirección o lugar para buscar");
          return;
        }

        searchLocationBtn.setAttribute("disabled", "true");
        searchLocationBtn.innerHTML = `
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="spinner">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" fill="none" opacity="0.25"/>
            <path d="M12 2 A10 10 0 0 1 22 12" stroke="currentColor" stroke-width="2" fill="none"/>
          </svg>
          Buscando...
        `;

        // Wait for Leaflet to be loaded
        await waitForLeaflet();

        const location = await searchLocationByAddress(query);

        if (location) {
          currentFilters.userLocation = {
            latitude: location.latitude,
            longitude: location.longitude,
          };
          currentFilters.distanceKm = parseInt(distanceRange.value) || 10;

          if (distanceSelector) distanceSelector.style.display = "block";
          if (locationInfo) {
            locationInfo.style.display = "block";
            const infoText = locationInfo.querySelector(".info-text");
            if (infoText) {
              infoText.innerHTML = `
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <path d="M12 16v-4m0-4h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Buscando cerca de: ${location.displayName.split(",").slice(0, 2).join(",")}
              `;
            }
          }

          // Initialize map with searched location
          initializeLocationMap(
            location.latitude,
            location.longitude,
            currentFilters.distanceKm,
          );

          applyFiltersAndRender();

          searchLocationBtn.removeAttribute("disabled");
          searchLocationBtn.innerHTML = `
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
              <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Buscar
          `;
        } else {
          alert(
            `No se encontró la ubicación "${query}". Intenta con otra búsqueda más específica.`,
          );
          searchLocationBtn.removeAttribute("disabled");
          searchLocationBtn.innerHTML = `
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2"/>
              <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Buscar
          `;
        }
      });

      // Allow Enter key to search
      searchLocationInput.addEventListener("keypress", (e) => {
        if (e.key === "Enter") {
          searchLocationBtn.click();
        }
      });
    }

    if (locationBtn && distanceRange) {
      locationBtn.addEventListener("click", async () => {
        locationBtn.setAttribute("disabled", "true");
        if (locationStatus)
          locationStatus.textContent = "Obteniendo ubicación...";

        // Wait for Leaflet to be loaded
        await waitForLeaflet();

        // Check if Leaflet is loaded
        if (typeof L === "undefined") {
          console.error("Leaflet failed to load!");
          if (locationStatus)
            locationStatus.textContent = "Error: Mapa no disponible";
          setTimeout(() => {
            locationBtn.removeAttribute("disabled");
            if (locationStatus)
              locationStatus.textContent = "Usar mi ubicación";
          }, 3000);
          return;
        }

        const location = await getUserLocation();
        console.log("User location:", location);

        if (location) {
          currentFilters.userLocation = location;
          currentFilters.distanceKm = parseInt(distanceRange.value) || 10;

          if (locationStatus)
            locationStatus.textContent = "Ubicación activada ✓";
          if (distanceSelector) distanceSelector.style.display = "block";
          if (locationInfo) {
            locationInfo.style.display = "block";
            const infoText = locationInfo.querySelector(".info-text");
            if (infoText) {
              infoText.innerHTML = `
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <path d="M12 16v-4m0-4h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                Mostrando eventos cerca de tu ubicación actual
              `;
            }
          }

          // Initialize map with user location and distance radius
          console.log("About to initialize map...");
          initializeLocationMap(
            location.latitude,
            location.longitude,
            currentFilters.distanceKm,
          );

          applyFiltersAndRender();
        } else {
          // Reset button immediately after error
          locationBtn.removeAttribute("disabled");
          if (locationStatus) locationStatus.textContent = "Usar mi ubicación";
        }
      });

      distanceRange.addEventListener("input", () => {
        if (distanceValue) {
          distanceValue.textContent = distanceRange.value;
        }

        if (currentFilters.userLocation) {
          currentFilters.distanceKm = parseInt(distanceRange.value) || 10;

          // Update circle radius on map
          if (radiusCircle) {
            radiusCircle.setRadius(currentFilters.distanceKm * 1000);
            if (locationMap) {
              locationMap.fitBounds(radiusCircle.getBounds(), {
                padding: [20, 20],
              });
            }
          }

          applyFiltersAndRender();
        }
      });
    }

    const clearFiltersBtn = document.getElementById("clear-filters");

    // Búsqueda con debounce
    let searchTimeout: NodeJS.Timeout;
    searchInput?.addEventListener("input", (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        currentFilters.search = (e.target as HTMLInputElement).value;
        applyFiltersAndRender();
      }, 300);
    });

    // Campos de rango de fechas
    dateFromInput?.addEventListener("change", (e) => {
      currentFilters.dateFrom = (e.target as HTMLInputElement).value;
      applyFiltersAndRender();
    });

    dateToInput?.addEventListener("change", (e) => {
      currentFilters.dateTo = (e.target as HTMLInputElement).value;
      applyFiltersAndRender();
    });

    priceMinInput?.addEventListener("input", (e) => {
      clearTimeout(priceTimeout);
      priceTimeout = setTimeout(() => {
        const minValue = (e.target as HTMLInputElement).value;
        currentFilters.priceMin = minValue;

        // Desactivar botones de precio si hay valor
        if (minValue || currentFilters.priceMax) {
          const priceBtns = document.querySelectorAll(
            ".filter-btn[data-price]",
          );
          priceBtns.forEach((btn) => btn.classList.remove("active"));
          currentFilters.price = "custom";
        }

        applyFiltersAndRender();
      }, 500);
    });

    priceMaxInput?.addEventListener("input", (e) => {
      clearTimeout(priceTimeout);
      priceTimeout = setTimeout(() => {
        const maxValue = (e.target as HTMLInputElement).value;
        currentFilters.priceMax = maxValue;

        // Desactivar botones de precio si hay valor
        if (maxValue || currentFilters.priceMin) {
          const priceBtns = document.querySelectorAll(
            ".filter-btn[data-price]",
          );
          priceBtns.forEach((btn) => btn.classList.remove("active"));
          currentFilters.price = "custom";
        }

        applyFiltersAndRender();
      }, 500);
    });

    // Ordenar
    sortFilter?.addEventListener("change", (e) => {
      currentFilters.sort = (e.target as HTMLSelectElement).value;
      applyFiltersAndRender();
    });

    // Limpiar filtros
    clearFiltersBtn?.addEventListener("click", () => {
      currentFilters = {
        category: "all",
        search: "",
        dateFrom: "",
        dateTo: "",
        price: "all",
        priceMin: "",
        priceMax: "",
        sort: "date-asc",
        userLocation: null,
        distanceKm: 10,
      };

      // Reset inputs
      if (searchInput) searchInput.value = "";
      if (dateFromInput) dateFromInput.value = "";
      if (dateToInput) dateToInput.value = "";
      if (priceMinInput) priceMinInput.value = "";
      if (priceMaxInput) priceMaxInput.value = "";
      if (sortFilter) sortFilter.value = "date-asc";

      // Reset location filter
      if (searchLocationInput) searchLocationInput.value = "";
      if (locationBtn) locationBtn.removeAttribute("disabled");
      if (locationStatus) locationStatus.textContent = "Usar mi ubicación";
      if (distanceSelector) distanceSelector.style.display = "none";
      if (locationInfo) locationInfo.style.display = "none";
      if (distanceRange) distanceRange.value = "10";
      if (distanceValue) distanceValue.textContent = "10";

      // Hide and reset map
      if (mapContainer) mapContainer.style.display = "none";
      if (locationMap) {
        locationMap.remove();
        locationMap = null;
        userMarker = null;
        radiusCircle = null;
      }

      // Reset filter buttons
      const categoryBtns = document.querySelectorAll(
        ".filter-btn[data-category]",
      );
      categoryBtns.forEach((btn) => {
        if (btn.getAttribute("data-category") === "all") {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });

      const priceBtns = document.querySelectorAll(".filter-btn[data-price]");
      priceBtns.forEach((btn) => {
        if (btn.getAttribute("data-price") === "all") {
          btn.classList.add("active");
        } else {
          btn.classList.remove("active");
        }
      });

      // Recargar página sin query params
      window.location.href = window.location.pathname;
    });
  });
</script>
