---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import ImageCarousel from "../../components/ImageCarousel.astro";
import { getUser } from "../../lib/auth";
import { supabase } from "../../lib/supabase";

const user = await getUser(Astro.cookies);
const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/dashboard");
}

// Obtener datos del evento
const { data: event, error: eventError } = await supabase
  .from("events")
  .select("*")
  .eq("id", id)
  .eq("status", "published")
  .single();

if (eventError || !event) {
  return Astro.redirect("/dashboard");
}

// Obtener datos del organizador por separado
const { data: organizer } = await supabase
  .from("profiles")
  .select("full_name, avatar_url")
  .eq("id", event.organizer_id)
  .single();

// Agregar organizer al evento
if (organizer) {
  event.organizer = organizer;
}

// Obtener TODAS las imágenes del evento (ordenadas, primero la principal)
const { data: eventImages } = await supabase
  .from("event_images")
  .select("image_url, is_primary, display_order")
  .eq("event_id", id)
  .order("display_order", { ascending: true });

// Obtener imagen principal como fallback
const primaryImage =
  eventImages?.find((img) => img.is_primary) || eventImages?.[0];

// Verificar si el usuario ya está inscrito
let isRegistered = false;
let registration = null;
if (user) {
  const { data: reg } = await supabase
    .from("event_registrations")
    .select("*")
    .eq("event_id", id)
    .eq("user_id", user.id)
    .single();

  if (reg) {
    isRegistered = true;
    registration = reg;
  }
}

// Contar inscripciones actuales
const { count: registrationsCount } = await supabase
  .from("event_registrations")
  .select("*", { count: "exact", head: true })
  .eq("event_id", id)
  .eq("status", "confirmed");

const spotsAvailable = event.capacity
  ? event.capacity - (registrationsCount || 0)
  : null;
const isFull = event.capacity && spotsAvailable !== null && spotsAvailable <= 0;

// Formatear fecha
const eventDate = new Date(event.start_date);
const formattedDate = eventDate.toLocaleDateString("es-CO", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});

const categoryIcons: Record<string, string> = {
  music: "🎵",
  sports: "⚽",
  tech: "💻",
  art: "🎨",
  food: "🍔",
  education: "📚",
  business: "💼",
  health: "🏥",
  entertainment: "🎭",
};
---

<Layout title={event.title}>
  <div class="event-detail-page">
    <Navbar
      activePage="explorar"
      isOrganizer={user?.user_metadata?.is_organizer}
      isAuthenticated={!!user}
    />

    <main class="main-content">
      <div class="container">
        <div class="f-buttons-container">
          <a href="/dashboard" class="back-link">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
            >
              <path
                d="M19 12H5M12 19l-7-7 7-7"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Volver a eventos
          </a>

          <div class="event-actions-buttons">
            <a
              href={`/edit-event/${event.id}`}
              class="btn-edit"
              title="Editar evento"
            >
              Editar
            </a>
            <button
              class="btn-delete"
              data-event-id={event.id}
              title="Eliminar evento"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="3 6 5 6 21 6"></polyline>
                <path
                  d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
                ></path>
                <line x1="10" y1="11" x2="10" y2="17"></line>
                <line x1="14" y1="11" x2="14" y2="17"></line>
              </svg>
            </button>
          </div>
        </div>

        <div class="event-detail-container">
          <!-- Carrusel de imágenes del evento -->
          <div class="event-image-section">
            {
              eventImages && eventImages.length > 0 ? (
                <ImageCarousel
                  images={eventImages.map((img) => img.image_url)}
                  altText={event.title}
                />
              ) : event.image_url ? (
                <img
                  src={event.image_url}
                  alt={event.title}
                  class="event-image"
                />
              ) : (
                <div class="event-image-placeholder">
                  <span class="placeholder-icon">
                    {categoryIcons[event.category] || "📅"}
                  </span>
                </div>
              )
            }
          </div>

          <div class="event-content-section">
            <!-- Cabecera del evento -->
            <div class="event-header">
              <span class="event-category-badge">
                <span>{categoryIcons[event.category] || "📅"}</span>
                <span>{event.category}</span>
              </span>
              <h1 class="event-title">{event.title}</h1>
            </div>

            <!-- Precio destacado -->
            <div class="meta-item price-item">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <circle
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="2"></circle>
                <line
                  x1="12"
                  y1="8"
                  x2="12"
                  y2="16"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></line>
                <path
                  d="M15 9.5a3 3 0 0 0-3-1.5 3 3 0 0 0 0 6 3 3 0 0 1 0 6 3 3 0 0 1-3-1.5"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path>
              </svg>
              <div class="price-content">
                <span class="price-label">Precio</span>
                <div class="price-amount">
                  <span class="price-value">
                    {
                      event.is_free
                        ? "Gratis"
                        : `$${event.price?.toLocaleString("es-CO")}`
                    }
                  </span>
                  {!event.is_free && <span class="price-currency">COP</span>}
                </div>
              </div>
            </div>

            <!-- Información clave -->
            <div class="event-meta">
              <div class="meta-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <rect
                    x="3"
                    y="4"
                    width="18"
                    height="18"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="2"></rect>
                  <line
                    x1="16"
                    y1="2"
                    x2="16"
                    y2="6"
                    stroke="currentColor"
                    stroke-width="2"></line>
                  <line
                    x1="8"
                    y1="2"
                    x2="8"
                    y2="6"
                    stroke="currentColor"
                    stroke-width="2"></line>
                  <line
                    x1="3"
                    y1="10"
                    x2="21"
                    y2="10"
                    stroke="currentColor"
                    stroke-width="2"></line>
                </svg>
                <span>{formattedDate}</span>
              </div>

              <div class="meta-item">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"
                    stroke="currentColor"
                    stroke-width="2"></path>
                  <circle
                    cx="12"
                    cy="10"
                    r="3"
                    stroke="currentColor"
                    stroke-width="2"></circle>
                </svg>
                <span>{event.city}, {event.country}</span>
              </div>

              {
                event.location_name && (
                  <div class="meta-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                    </svg>
                    <span>{event.location_name}</span>
                  </div>
                )
              }

              {
                event.address && (
                  <div class="meta-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <circle
                        cx="12"
                        cy="9"
                        r="2.5"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                    </svg>
                    <span>{event.address}</span>
                  </div>
                )
              }

              {
                event.capacity && (
                  <div class="meta-item capacity-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle
                        cx="9"
                        cy="7"
                        r="4"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <path
                        d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                    </svg>
                    <span>
                      {spotsAvailable !== null
                        ? spotsAvailable > 0
                          ? `${spotsAvailable} cupos disponibles`
                          : "Lleno"
                        : `${event.capacity} cupos`}
                    </span>
                  </div>
                )
              }

              {
                event.organizer && (
                  <div class="meta-item">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle
                        cx="12"
                        cy="7"
                        r="4"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                    </svg>
                    <span>
                      Organizador: {event.organizer.full_name || "Desconocido"}
                    </span>
                  </div>
                )
              }
            </div>

            <!-- Descripción -->
            <div class="event-description">
              <h2>Acerca del evento</h2>
              <p>{event.description || "Sin descripción disponible"}</p>
            </div>

            <!-- Mapa de ubicación -->
            {
              event.latitude && event.longitude && (
                <div class="event-location-map">
                  <h2>Ubicación</h2>
                  <div id="event-map" class="map-container" />
                </div>
              )
            }

            <!-- Formulario de inscripción
            <div class="registration-section">
              {
                isRegistered ? (
                  <div class="already-registered">
                    <div class="success-icon">✓</div>
                    <h3>¡Ya estás inscrito!</h3>
                    <p>
                      Tu número de ticket:{" "}
                      <strong>{registration.ticket_number}</strong>
                    </p>
                    <p class="registration-date">
                      Registrado el{" "}
                      {new Date(registration.created_at).toLocaleDateString(
                        "es-CO",
                      )}
                    </p>
                  </div>
                ) : isFull ? (
                  <div class="event-full">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                      <circle
                        cx="12"
                        cy="12"
                        r="10"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <path
                        d="M15 9l-6 6M9 9l6 6"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                      />
                    </svg>
                    <h3>Evento lleno</h3>
                    <p>Lo sentimos, no hay cupos disponibles</p>
                  </div>
                ) : !user ? (
                  <div class="login-required">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none">
                      <path
                        d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                      <circle
                        cx="12"
                        cy="7"
                        r="4"
                        stroke="currentColor"
                        stroke-width="2"
                      />
                    </svg>
                    <h3>Inicia sesión para inscribirte</h3>
                    <a href="/login" class="btn-primary">
                      Iniciar sesión
                    </a>
                  </div>
                ) : (
                  <form id="registration-form" class="registration-form">
                    <h3>Inscríbete al evento</h3>

                    <div class="form-group">
                      <label for="full_name">Nombre completo *</label>
                      <input
                        type="text"
                        id="full_name"
                        name="full_name"
                        value={user.user_metadata?.full_name || ""}
                        required
                        class="form-input"
                      />
                    </div>

                    <div class="form-group">
                      <label for="email">Correo electrónico *</label>
                      <input
                        type="email"
                        id="email"
                        name="email"
                        value={user.email || ""}
                        required
                        class="form-input"
                      />
                    </div>

                    <div class="form-group">
                      <label for="phone">Teléfono *</label>
                      <input
                        type="tel"
                        id="phone"
                        name="phone"
                        placeholder="+57 300 123 4567"
                        required
                        class="form-input"
                      />
                    </div>

                    <div class="form-group">
                      <label for="additional_info">Información adicional</label>
                      <textarea
                        id="additional_info"
                        name="additional_info"
                        rows="3"
                        placeholder="¿Algo que quieras que sepamos?"
                        class="form-textarea"
                      />
                    </div>

                    <button type="submit" class="btn-register" id="submit-btn">
                      <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                      >
                        <path
                          d="M9 11l3 3L22 4"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                        />
                        <path
                          d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                          stroke="currentColor"
                          stroke-width="2"
                        />
                      </svg>
                      <span>Confirmar inscripción</span>
                    </button>

                    <p class="form-note">
                      Al inscribirte aceptas los términos y condiciones del
                      evento
                    </p>

                    <div
                      id="error-message"
                      class="error-message"
                      style="display: none;"
                    />
                    <div
                      id="success-message"
                      class="success-message"
                      style="display: none;"
                    />
                  </form>
                )
              }
            </div> -->
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ eventId: id }}>
  const form = document.getElementById("registration-form");
  const submitBtn = document.getElementById("submit-btn");
  const errorMsg = document.getElementById("error-message");
  const successMsg = document.getElementById("success-message");

  if (form) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Deshabilitar botón
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = "<span>Procesando...</span>";
      }

      // Ocultar mensajes previos
      if (errorMsg) errorMsg.style.display = "none";
      if (successMsg) successMsg.style.display = "none";

      const formData = new FormData(form);
      const data = {
        event_id: eventId,
        full_name: formData.get("full_name"),
        email: formData.get("email"),
        phone: formData.get("phone"),
        additional_info: formData.get("additional_info"),
      };

      try {
        const response = await fetch("/api/registrations/create", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || "Error al procesar la inscripción");
        }

        // Mostrar mensaje de éxito
        if (successMsg) {
          successMsg.textContent = `¡Inscripción exitosa! Tu número de ticket es: ${result.ticket_number}`;
          successMsg.style.display = "block";
        }

        // Recargar página después de 2 segundos
        setTimeout(() => {
          window.location.reload();
        }, 2000);
      } catch (error) {
        if (errorMsg) {
          errorMsg.textContent = error.message;
          errorMsg.style.display = "block";
        }

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = `
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
              <path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" stroke="currentColor" stroke-width="2"/>
            </svg>
            <span>Confirmar inscripción</span>
          `;
        }
      }
    });
  }
</script>

<script
  define:vars={{
    latitude: event.latitude,
    longitude: event.longitude,
    locationName: event.location_name,
  }}
>
  // Inicializar mapa de ubicación del evento
  document.addEventListener("DOMContentLoaded", function () {
    if (latitude && longitude) {
      const mapElement = document.getElementById("event-map");
      if (mapElement && typeof L !== "undefined") {
        const eventMap = L.map("event-map").setView([latitude, longitude], 17);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
          attribution: "© OpenStreetMap contributors",
          maxZoom: 19,
        }).addTo(eventMap);

        const marker = L.marker([latitude, longitude]).addTo(eventMap);
        if (locationName) {
          marker.bindPopup(locationName).openPopup();
        }
      }
    }
  });
</script>

