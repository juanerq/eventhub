  .event-detail-page {
    min-height: 100vh;
    background: linear-gradient(135deg, #020617 0%, #0c4a6e 50%, #1e293b 100%);
  }

  .main-content {
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text);
  }

  .f-buttons-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .event-actions-buttons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-edit,
  .btn-delete {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    height: 40px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-edit {
    padding: 0 10px;
    background: linear-gradient(135deg, var(--violet-600), var(--fuchsia-600));
    color: white;
    box-shadow: 0 4px 12px rgba(147, 51, 234, 0.3);
  }

  .btn-edit:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(147, 51, 234, 0.5);
  }

